                  "    pm.environment.set('token', jsonData.usuario.token);",
                  "    pm.collectionVariables.set('token', jsonData.usuario.token);",
                  "    pm.globals.set('token', jsonData.usuario.token);",
                  "    pm.test('Token JWT guardado en environment/collection/global', function () {",
                  "        pm.expect(jsonData.usuario.token).to.exist;",
                  "    });",
                  "} else {",
